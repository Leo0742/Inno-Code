{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@inno/engine": [
        "../../packages/engine/src/index.ts"
      ]
    }
  },
  "include": [
    "src",
    "electron",
    "vite.config.ts"
  ]
}