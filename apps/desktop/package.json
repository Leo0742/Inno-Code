{
  "name": "@inno/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:renderer:dev\" \"npm:electron:dev\" \"npm:engine:watch\"",
    "build": "tsc -p tsconfig.json --noEmit && vite build && npm run -w @inno/engine build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "electron:dev": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron ./electron/main.js",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "renderer:dev": "vite",
    "engine:watch": "npm run -w @inno/engine build:watch",
    "test": "node --test electron/state.test.js"
  },
  "dependencies": {
    "@inno/engine": "0.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^36.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.1",
    "electron-builder": "^24.13.3",
    "concurrently": "^9.0.1",
    "wait-on": "^8.0.1",
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "com.innocode.desktop",
    "productName": "Inno Code",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
